{
  "expo": {
    "name": "Pocket-No",
    "slug": "pocket-no",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "scheme": "pocketno",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "icon": "./assets/pocket-no.icon",
      "bundleIdentifier": "dev.ctey.pocketno",
      "appleTeamId": "RXALJSS7PH",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.ctey.pocketno",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/app/android-icon-foreground.png",
        "backgroundImage": "./assets/app/android-icon-background.png",
        "monochromeImage": "./assets/app/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "name": "Pocket No",
      "shortName": "Pocket No",
      "description": "Witty excuses to say no, one tap away."
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/app/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Pocket-No uses the microphone to turn your voice into a personalized no.",
          "enableBackgroundPlayback": false
        }
      ],
      "@bacons/apple-targets",
      "./plugins/with-screenless-quick-copy"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
