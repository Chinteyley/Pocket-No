{
  "expo": {
    "name": "Pocket-No",
    "slug": "pocket-no",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "scheme": "pocketno",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/pocket-no.icon",
      "bundleIdentifier": "dev.ctey.pocketno",
      "appleTeamId": "RXALJSS7PH"
    },
    "android": {
      "package": "dev.ctey.pocketno",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/app/android-icon-foreground.png",
        "backgroundImage": "./assets/app/android-icon-background.png",
        "monochromeImage": "./assets/app/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "favicon": "./assets/app/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/app/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@bacons/apple-targets",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "dev.ctey.pocketno.ExpoWidgetsTarget",
          "groupIdentifier": "group.dev.ctey.pocketno",
          "widgets": [
            {
              "name": "PocketNoWidget",
              "displayName": "Pocket-No",
              "description": "A quick reason for saying no.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryInline"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
